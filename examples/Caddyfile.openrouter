# Legacy example
# This file uses the older llm_router syntax and is kept only as historical reference.
# Prefer the route-oriented handle_llm_api + target configuration shown in README.md.

localhost:8082 {
	route /v1/* {
		llm_router {
			# Use OpenRouter as primary provider
			provider openrouter

			# OpenRouter API key
			api_key {$OPENROUTER_API_KEY}

			# Fallback to direct providers if OpenRouter fails
			fallback openai anthropic

			# Fallback API keys
			api_key openai {$OPENAI_API_KEY}
			api_key anthropic {$ANTHROPIC_API_KEY}

			# Model mapping for OpenRouter
			# OpenRouter uses provider/model format
			map haiku openai/gpt-4o-mini
			map sonnet anthropic/claude-3-5-sonnet-20241022

			# Enable advanced features
			max_retries 5
			retry_delay 1

			log_requests
		}
	}
}
