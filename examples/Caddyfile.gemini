# Caddy LLM Router - Gemini Configuration
# This configuration proxies Anthropic API requests to Google Gemini

localhost:8082 {
	route /v1/* {
		llm_router {
			# Use Google Gemini as provider
			provider gemini

			# Gemini API key
			api_key {$GEMINI_API_KEY}

			# Map Claude models to Gemini models
			map haiku gemini-2.0-flash-exp
			map sonnet gemini-2.5-pro-exp
			map opus gemini-2.5-pro-exp

			# Retry configuration
			max_retries 3
			retry_delay 2

			# Enable request logging
			log_requests
		}
	}
}
