# Caddy LLM Router - Basic Configuration
# This configuration proxies Anthropic API requests to OpenAI

{
	# Global options
	admin localhost:2019
}

localhost:8082 {
	# Enable access log
	log {
		output file /var/log/caddy/llm-access.log
		format json
	}

	route /v1/* {
		llm_router {
			# Provider: openai, gemini, anthropic, groq, ollama, mistral, openrouter
			provider openai

			# API key (can use environment variables with {$ENV_VAR})
			api_key {$OPENAI_API_KEY}

			# Model mapping - map Claude models to provider models
			map haiku gpt-4o-mini
			map sonnet gpt-4o

			# Retry configuration
			max_retries 3
			retry_delay 2

			# Logging
			log_level info
			log_requests
		}
	}
}

