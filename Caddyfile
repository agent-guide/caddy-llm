# Caddy LLM AI Gateway
# Caddy App module ID: "llm"
# HTTP handler module IDs:
# - "http.handlers.llm_api.openai" / "http.handlers.llm_api.anthropic" (Caddyfile directive: "handle_llm_api")
# - "http.handlers.llm_admin" (Caddyfile directive: "handle_llm_admin")

{
	admin localhost:2019

	llm {
		provider openai
		provider anthropic
	}
}

localhost:8082 {
	log {
		output stderr
		format console
	}

	# LLM API routes
	route /v1/* {
		handle_llm_api openai {
			route_id openai-chat
		}
		handle_llm_api anthropic {
			route_id openai-chat
		}

		agent_gateway_route openai-chat {
			target openai
		}
	}

	# Admin routes
	route /admin/* {
		handle_llm_admin
	}
}
