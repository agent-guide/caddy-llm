# Caddy LLM AI Gateway
# Caddy App module ID: "llm"
# HTTP handler module IDs:
# - "http.handlers.llm_api" (Caddyfile directive: "handle_llm_api")
# - "http.handlers.llm_admin" (Caddyfile directive: "handle_llm_admin")

{
	admin localhost:2019
}

localhost:8082 {
	log {
		output stderr
		format console
	}

	# LLM API routes
	route /v1/* {
		handle_llm_api {
			llm_api openai
			llm_api anthropic
		}
	}

	# Admin routes
	route /admin/* {
		handle_llm_admin
	}
}
