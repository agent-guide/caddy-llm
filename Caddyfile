# Caddy LLM AI Gateway
# HTTP handler module ID: "http.handlers.llm"  (Caddyfile directive: "llm")

{
	admin localhost:2019
}

localhost:8082 {
	log {
		output stderr
		format console
	}

	# LLM API routes (OpenAI/Anthropic/Gemini compatible)
	route /v1/* {
		llm {
			default_provider openai
			config_dsn {$LLM_CONFIG_DSN:llm_gateway.db}
		}
	}

	# Admin API routes
	route /admin/* {
		llm {
			default_provider openai
			config_dsn {$LLM_CONFIG_DSN:llm_gateway.db}
		}
	}
}
