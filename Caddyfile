# Caddy Agent Gateway
# Caddy App module ID: "agent_gateway"
# HTTP handler module IDs:
# - "http.handlers.openai" / "http.handlers.anthropic" (Caddyfile directive: "handle_llm_api")
# - "http.handlers.llm_admin" (Caddyfile directive: "handle_llm_admin")

{
	admin localhost:2019

	agent_gateway {
		provider openai {
			default_model gpt-4.1
		}

		config_store sqlite {
			path ./data/configstore.db
		}

		route openai-chat {
			require_local_api_key
			allowed_model gpt-4.1
			allowed_model gpt-4.1-mini
			target openai
		}
	}
}

localhost:8082 {
	log {
		output stderr
		format console
	}

	# LLM API routes
	route /v1/* {
		handle_llm_api openai {
			route_id openai-chat
		}
		handle_llm_api anthropic {
			route_id openai-chat
		}
	}

	# Admin routes
	route /admin/* {
		handle_llm_admin {
			admin_user default
			admin_password_hash dummy
		}
	}
}
